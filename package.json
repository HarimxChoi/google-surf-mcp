{
  "name": "google-surf-mcp",
  "version": "0.3.2",
  "mcpName": "io.github.HarimxChoi/google-surf-mcp",
  "description": "MCP server for Google search via warm Chrome profile. No API key.",
  "type": "module",
  "bin": {
    "google-surf-mcp": "build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "bootstrap": "node build/bootstrap.js",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "google",
    "google-search",
    "search",
    "web-search",
    "serp",
    "playwright",
    "headless-browser",
    "claude"
  ],
  "author": "harimxchoi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HarimxChoi/google-surf-mcp.git"
  },
  "homepage": "https://github.com/HarimxChoi/google-surf-mcp#readme",
  "bugs": "https://github.com/HarimxChoi/google-surf-mcp/issues",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@mozilla/readability": "^0.6.0",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.17.10",
    "@types/turndown": "^5.0.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  }
}
